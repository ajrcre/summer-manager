# Postgres connection string used by the app at runtime.
# Locally: Docker Postgres. Production: Neon — use the POOLED string (host has "-pooler").
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# Optional: DIRECT (unpooled) Postgres string, used only by Prisma migrations
# (they need a non-pooled connection). On Vercel's Neon integration this is provided
# automatically as DATABASE_URL_UNPOOLED, which the app also reads — so you usually
# don't need to set DIRECT_URL yourself. Locally it falls back to DATABASE_URL.
# DIRECT_URL="postgresql://user:password@host:5432/dbname?schema=public"

# Shared family PIN that unlocks editor actions (create/edit/delete, rewards, members)
FAMILY_EDITOR_PIN="1234"

# Secret used to sign the editor session cookie (use a long random value in production)
EDITOR_COOKIE_SECRET="change-me-to-a-long-random-string"
