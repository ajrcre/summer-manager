# Postgres connection string. Locally: Docker Postgres. Production: Neon (Vercel Postgres).
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# Shared family PIN that unlocks editor actions (create/edit/delete, rewards, members)
FAMILY_EDITOR_PIN="1234"

# Secret used to sign the editor session cookie (use a long random value in production)
EDITOR_COOKIE_SECRET="change-me-to-a-long-random-string"
